generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id               String    @id @default(uuid()) @db.Uuid
  clerkId          String    @unique @map("clerk_id")
  email            String    @unique
  name             String?
  avatarUrl        String?   @map("avatar_url")
  plan             String    @default("free")
  creditsRemaining Int       @default(10) @map("credits_remaining")
  creditResetDate  DateTime  @map("credit_reset_date")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  deletedAt        DateTime? @map("deleted_at")

  @@index([clerkId])
  @@index([email])
  @@map("users")
}

model Workspace {
  id              String    @id @default(uuid()) @db.Uuid
  userId          String    @map("user_id")
  name            String    @db.VarChar(100)
  idea            String
  industry        String?   @db.VarChar(100)
  startupStage    String?   @default("idea") @map("startup_stage") @db.VarChar(50)
  slug            String?   @db.VarChar(120)
  status          String    @default("active")
  lastGeneratedAt DateTime? @map("last_generated_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  archivedAt      DateTime? @map("archived_at")
  deletedAt       DateTime? @map("deleted_at")

  sections      Section[]
  conversations Conversation[]

  @@index([userId, status])
  @@index([updatedAt(sort: Desc)])
  @@map("workspaces")
}

model Section {
  id               String    @id @default(uuid()) @db.Uuid
  workspaceId      String    @map("workspace_id") @db.Uuid
  type             String    @db.VarChar(50)
  content          String?
  generationStatus String    @default("pending") @map("generation_status")
  currentVersion   Int       @default(0) @map("current_version")
  lastGeneratedAt  DateTime? @map("last_generated_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, type])
  @@index([workspaceId])
  @@map("sections")
}

model ChatMessage {
  id             String   @id @default(uuid()) @db.Uuid
  conversationId String   @map("conversation_id") @db.Uuid
  userId         String   @map("user_id")
  role           String   @db.VarChar(20)
  content        String
  createdAt      DateTime @default(now()) @map("created_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt(sort: Asc)])
  @@map("chat_messages")
}

model Conversation {
  id          String    @id @default(uuid()) @db.Uuid
  userId      String    @map("user_id")
  title       String    @default("New Chat") @db.VarChar(200)
  workspaceId String?   @map("workspace_id") @db.Uuid
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  messages ChatMessage[]
  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)

  @@index([userId, updatedAt(sort: Desc)])
  @@map("conversations")
}

model Subscription {
  id                    String    @id @default(uuid()) @db.Uuid
  userId                String    @map("user_id")
  plan                  String    @default("free")
  status                String    @default("active")
  creditsRemaining      Int       @default(10) @map("credits_remaining")
  monthlyCredits        Int       @default(10) @map("monthly_credits")
  razorpayCustomerId    String?   @map("razorpay_customer_id")
  razorpaySubscriptionId String?  @map("razorpay_subscription_id")
  renewalDate           DateTime? @map("renewal_date")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  @@unique([userId])
  @@index([userId])
  @@map("subscriptions")
}

model Payment {
  id                String   @id @default(uuid()) @db.Uuid
  userId            String   @map("user_id")
  amount            Int
  currency          String   @default("INR") @db.VarChar(10)
  status            String   @default("pending")
  razorpayOrderId   String?  @map("razorpay_order_id")
  razorpayPaymentId String?  @map("razorpay_payment_id")
  plan              String
  createdAt         DateTime @default(now()) @map("created_at")

  @@index([userId, createdAt(sort: Desc)])
  @@map("payments")
}

model CreditTransaction {
  id               String   @id @default(uuid()) @db.Uuid
  userId           String   @map("user_id")
  action           String
  creditsUsed      Int      @map("credits_used")
  creditsRemaining Int      @map("credits_remaining")
  createdAt        DateTime @default(now()) @map("created_at")

  @@index([userId, createdAt(sort: Desc)])
  @@map("credit_transactions")
}
